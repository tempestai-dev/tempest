{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tempest",
  "version": "0.1.2",
  "identifier": "com.user.tempest",
  "build": {
    "beforeDevCommand": "npm run build:atlas && npm run dev:frontend",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:atlas && npm run build:frontend",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tempest",
        "width": 800,
        "height": 600,
        "center": true,
        "decorations": false,
        "maximized": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/gsvprharsha/tempest/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDJFOEZGODJEOUU4MTc1REUKUldUZWRZR2VMZmlQTHZvQ1FqdklsaUZFSU82TEdKNmFnRlFpcERZV0VDandod1owWVUvd1hKL0MK",
      "windows": {
        "installMode": "quiet"
      }
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "resources": {
      "resources/atlas/**/*": "atlas/",
      "icons/128x128.png": "icon.png"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
